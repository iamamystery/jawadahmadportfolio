# ---------------------------------------------------------------------------
# Copy to .env.local and fill in. Also set these in Vercel:
#   Project → Settings → Environment Variables (Production + Preview)
# ---------------------------------------------------------------------------

# Required. Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Optional. Defaults to imjawadahmad.work@gmail.com.
# NOTE: with the shared sender below, Resend only delivers to the account
# owner's address. Until a domain is verified, set this to that address.
CONTACT_TO=

# Optional. Defaults to "Phantex HQ <onboarding@resend.dev>".
# Resend's shared sender needs no DNS setup but only delivers to the Resend
# account owner's address. Verify a domain for real-world sending.
CONTACT_FROM=
